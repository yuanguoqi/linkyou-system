{
  // ===================== 应用基础配置 =====================
  "App": {
    // 前端地址（CORS 白名单，多个用逗号分隔）
    "CorsOrigins": "http://localhost:5173,http://localhost:3000,https://yourdomain.com",
    // 自身 API 地址（用于生成 Swagger 等）
    "SelfUrl": "http://localhost:5000"
  },

  // ===================== 数据库连接 =====================
  "ConnectionStrings": {
    // 主数据库连接字符串（PostgreSQL）
    "Default": "Host=localhost;Port=5432;Database=LinkyouSystem;Username=postgres;Password=your_password;Include Error Detail=true"
  },

  // ===================== JWT 认证配置 =====================
  "AuthServer": {
    // JWT 签发者（本系统自签 JWT 时与 SelfUrl 相同）
    "Authority": "http://localhost:5000",
    // JWT 受众标识
    "Audience": "LinkyouSystem",
    // 开发环境关闭 HTTPS 强制（生产环境应设为 true）
    "RequireHttpsMetadata": false
  },

  // ===================== JWT Token 生成配置 =====================
  "Jwt": {
    // 签名密钥（至少 32 字节，生产环境从密钥管理服务读取）
    "SigningKey": "LinkyouSystemJwtSigningKey2024!@#$%^",
    // 颁发者
    "Issuer": "LinkyouSystem",
    // 受众
    "Audience": "LinkyouSystem",
    // 访问令牌过期时间（分钟）
    "AccessTokenExpirationMinutes": 60,
    // 刷新令牌过期时间（天）
    "RefreshTokenExpirationDays": 30
  },

  // ===================== 日志配置（Serilog） =====================
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Volo.Abp": "Warning"
      }
    }
  },

  // ===================== ABP 多租户配置 =====================
  "MultiTenancy": {
    // 启用多租户（通过请求头 __tenant 传递租户名称）
    "IsEnabled": true
  },

  // ===================== Redis 缓存（可选，当前使用内存缓存） =====================
  // "Redis": {
  //   "Configuration": "localhost:6379"
  // },

  // ===================== ASP.NET Core 日志配置 =====================
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // ===================== HTTPS 重定向配置 =====================
  "AllowedHosts": "*"
}
