    <PackageReference Include="Volo.Abp.PermissionManagement.EntityFrameworkCore" Version="10.4.0" />
    <!-- 后台作业 EF Core（存储后台任务） -->
    <PackageReference Include="Volo.Abp.BackgroundJobs.EntityFrameworkCore" Version="10.4.0" />
    <!-- Autofac DI 容器（MigratorModule 使用） -->
    <PackageReference Include="Volo.Abp.Autofac" Version="10.4.0" />
