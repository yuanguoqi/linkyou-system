    <!-- 身份管理 EF Core -->
    <PackageReference Include="Volo.Abp.Identity.EntityFrameworkCore" Version="10.4.0" />
    <!-- 多租户管理 EF Core -->
    <PackageReference Include="Volo.Abp.TenantManagement.EntityFrameworkCore" Version="10.4.0" />
